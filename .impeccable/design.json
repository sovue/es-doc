      "color": "var(--text-soft)"
    },
    "anchorLinks": {
      "defaultOpacity": 0.3,
      "revealOn": ["parent :hover", ":focus-visible"],
      "note": "Must be visible at focus-visible — keyboard users tab to these links",
      "scrollMarginTop": "76px (52px nav + 24px clearance)"
    },
    "anchorFlash": {
      "trigger": ":target pseudo-class",
      "animation": "flash 1s ease — background fades from target-bg to transparent",
      "reducedMotion": "animation disabled entirely"
    }
  },

  "focusStyle": {
    "outline": "2px solid var(--accent)",
    "offsets": {
      "contained": "-2px to -3px (nav links, search button)",
      "outside": "2–3px (logo, section rows, footer links)"
    },
    "pseudo": "focus-visible only"
  },

  "accessibility": {
    "target": "WCAG 2.1 AA",
